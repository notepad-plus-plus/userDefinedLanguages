<NotepadPlus>
	<functionList>
		<!-- ========================================= [ Initialization File ] -->
		<!-- File format used for THinkScript Scripts                                         -->

		<parser
			displayName="Think Scripts"
			id         ="think_scripts"
			commentExpr="Think Scripts                                # Single Line Comment
						"
		>
			<function
				mainExpr="(?ix)^script\s(\w+)"
			>
				<functionName>
					<nameExpr expr="(?ix)^script\s(\w+)"/>
				</functionName>
			</function>
		</parser>
	</functionList>
</NotepadPlus>